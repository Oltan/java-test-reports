# Jira Configuration
JIRA_URL=https://your-jira-instance.atlassian.net
JIRA_PAT=your_jira_personal_access_token
JIRA_PROJECT_KEY=TEST

# SMTP Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your_smtp_password

# DOORS Configuration
DOORS_PATH=C:\Program Files\IBM\DOORS\bin\dxl.exe

# Allure CLI Configuration
ALLURE_PATH=C:\tools\allure-2.33.0\bin\allure.bat

# Web Server Configuration
WEB_SERVER_PORT=8080

# Orchestrator Configuration
ORCHESTRATOR_SMTP_HOST=smtp.example.com
ORCHESTRATOR_SMTP_PORT=587
ORCHESTRATOR_SMTP_USER=your-email@example.com
ORCHESTRATOR_SMTP_PASS=your_smtp_password
ORCHESTRATOR_JIRA_URL=https://your-jira-instance.atlassian.net
ORCHESTRATOR_JIRA_PAT=your_jira_personal_access_token
ORCHESTRATOR_JIRA_PROJECT_KEY=TEST

# Allure Results Directory
# Where Maven writes allure-results after running tests.
# Default: <repo_root>/test-core/target/allure-results
# Example for a custom project: ALLURE_RESULTS_DIR=C:\projects\myproject\target\allure-results
# ALLURE_RESULTS_DIR=

# Maven Module Configuration
# The sub-module name inside this repo that contains your tests.
# Runs as: mvn -pl <MAVEN_MODULE> test -Dcucumber.filter.tags=...
# Allure results are read from: <MAVEN_MODULE>/target/allure-results
# Default (if not set): test-core
MAVEN_MODULE=myproject

# JWT Configuration
JWT_SECRET=your_secret_key_here_change_in_production